# =============================================================================
# .env.example — copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── Environment ───────────────────────────────────────────────────────────────
ENV=dev                                    # local | dev | prod

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012

# ── Kafka / MSK ───────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092     # local Docker
# KAFKA_BOOTSTRAP_SERVERS=b-1.banking-kafka-dev.xxxxx.c2.kafka.eu-west-1.amazonaws.com:9098
SCHEMA_REGISTRY_URL=http://localhost:8081
AWS_MSK_IAM_AUTH=false                    # true in AWS environments

# ── Redshift ──────────────────────────────────────────────────────────────────
REDSHIFT_HOST=banking-dev.xxxxxxxxx.eu-west-1.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=banking
REDSHIFT_USER=banking_admin
REDSHIFT_PASSWORD=                        # Use IAM in production

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PII_SALT=local-dev-salt-change-in-production

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=               # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=          # random 32-char string

# ── Slack Alerts ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# ── Great Expectations ────────────────────────────────────────────────────────
GE_DATASOURCE_NAME=banking_delta_lake

# ── Spark (local) ─────────────────────────────────────────────────────────────
PYSPARK_PYTHON=python3
JAVA_HOME=/usr/lib/jvm/temurin-11
